{\n  \"manifest_version\": 3,\n  \"name\": \"Wingman\",\n  \"version\": \"0.1.0\",\n  \"description\": \"AI chat sidebar for Thunderbird — search, read, move, tag and draft emails using natural language\",\n  \"permissions\": [\n    \"accountsRead\",\n    \"messagesRead\",\n    \"messagesMove\",\n    \"messagesModify\",\n    \"messagesTags\",\n    \"accountsFolders\",\n    \"compose\",\n    \"storage\"\n  ],\n  \"background\": {\n    \"scripts\": [\"background.js\"]\n  },\n  \"sidebar_action\": {\n    \"default_title\": \"Wingman\",\n    \"default_panel\": \"sidebar/sidebar.html\",\n    \"default_icon\": \"icons/icon.png\"\n  },\n  \"options_ui\": {\n    \"page\": \"options/options.html\",\n    \"open_in_tab\": false\n  },\n  \"icons\": {\n    \"48\": \"icons/icon.png\",\n    \"96\": \"icons/icon.png\"\n  }\n}\n